# ===========================================
# Calamo — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- LLM Provider ----
GEMINI_API_KEY=your_gemini_api_key_here
PROXYAPI_KEY=your_proxyapi_key_here

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./calamo.db
POSTGRES_USER=calamo_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=calamo

# ---- Auth ----
SECRET_KEY=your_secret_key_minimum_32_chars_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback/google

# ---- Telegram Notifications ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_TOPIC_ID=2

# ---- Payment (RollyPay) ----
ROLLYPAY_API_KEY=your_rollypay_api_key
ROLLYPAY_SECRET_KEY=your_rollypay_secret_key
ROLLYPAY_BASE_URL=https://rollypay.io/api/v1

# ---- Deployment (for deploy.sh) ----
DEPLOY_HOST=your_server_ip_or_hostname
DEPLOY_USER=root
SSH_KEY_PATH=~/.ssh/id_rsa

# ---- Debug ----
DEBUG=true
